    # ───────── GAME 3 DRAW ─────────
    def draw_game3(self):
        pyxel.cls(0)

        for card in self.g3_cards:
            if card["flipped"] or card in self.g3_revealed:
                pyxel.rect(card["x"], card["y"], self.g3_card_w, self.g3_card_h, 7)
                self.draw_game3_shape(card)
            else:
                self.draw_game3_ram(card)

        self.draw_game3_player()

        pyxel.text(5, H - 10, "ARROWS move  SPACE flip  TAB menu", 5)

        if self.g3_congrats_show:
            msg = "CONGRATS!!"
            pyxel.text((W - len(msg) * 4) // 2, 20, msg, 3)

    def draw_game3_player(self):
        pyxel.rect(self.g3_px - 3, self.g3_py - 6, 6, 6, 4)

    def draw_game3_shape(self, card):
        cx = card["x"] + self.g3_card_w // 2
        cy = card["y"] + self.g3_card_h // 2
        col = card["color"]
        shape = card["shape"]

        if shape == "circle":
            pyxel.circ(cx, cy, 5, col)
        elif shape == "square":
            pyxel.rect(cx - 5, cy - 5, 10, 10, col)
        elif shape == "heart":
            pyxel.tri(cx, cy - 6, cx - 6, cy + 4, cx + 6, cy + 4, col)
        elif shape == "rectangle":
            pyxel.rect(cx - 8, cy - 3, 16, 6, col)
        elif shape == "trapezoid":
            pyxel.tri(cx - 6, cy + 5, cx - 4, cy - 5, cx + 4, cy - 5, col)
            pyxel.tri(cx - 6, cy + 5, cx + 6, cy + 5, cx + 4, cy - 5, col)
        elif shape == "diamond":
            pyxel.tri(cx, cy - 6, cx - 6, cy, cx + 6, cy, col)
            pyxel.tri(cx, cy + 6, cx - 6, cy, cx + 6, cy, col)
        elif shape == "oval":
            pyxel.rect(cx - 2, cy - 6, 4, 12, col)
            pyxel.rect(cx - 6, cy - 2, 12, 4, col)
        elif shape == "hexagon":
            pyxel.rect(cx - 1, cy - 6, 2, 12, col)
            pyxel.rect(cx - 6, cy - 1, 12, 2, col)
            pyxel.rect(cx - 4, cy - 4, 8, 8, col)

    def draw_game3_ram(self, card):
        pyxel.rect(card["x"], card["y"], self.g3_card_w, self.g3_card_h, 2)

        text = "R.A.M."
        text_width = len(text) * 4
        tx = card["x"] + (self.g3_card_w - text_width) // 2
        ty = card["y"] + self.g3_card_h // 2 - 2

        pyxel.text(tx, ty, text, 1)

    # ───────── GAME 4 DRAW ─────────
    def draw_game4(self):
        pyxel.cls(0)

        for x in range(0, W, 16):
            pyxel.pset(x, 15, 1)
            pyxel.pset(x + 8, 25, 1)

        pyxel.rect(self.g4_player_x, self.g4_player_y, 14, 8, 11)
        pyxel.rect(self.g4_player_x + 5, self.g4_player_y - 3, 4, 3, 11)

        for bullet in self.g4_bullets:
            pyxel.rect(bullet["x"], bullet["y"], 2, 4, 10)

        for bullet in self.g4_enemy_bullets:
            pyxel.rect(bullet["x"], bullet["y"], 2, 4, 8)

        for enemy in self.g4_enemies:
            if enemy["alive"]:
                self.draw_invader(int(enemy["x"]), int(enemy["y"]))

        pyxel.text(10, 10, f"SCORE: {self.g4_score}", 7)
        pyxel.text(W - 60, 10, f"LIVES: {self.g4_lives}", 7)
