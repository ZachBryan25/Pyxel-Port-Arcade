import pyxel
import random
import math
import time

# SCREEN SIZE
W, H = 320, 240


class App:
    def __init__(self):
        pyxel.init(W, H, title="Pyxel Port", fps=60)

        self.state = "menu"

        self.games = [
            "Dungeon Shooter",
            "Pong",
            "Random Access Match",
            "Space Invaders",
            "Game 5"
        ]

        self.selected = 0

        self.max_waves = 5
        self.reset_game1()
        self.reset_game2()
        self.init_game3()
        self.start_game3()
        self.reset_game4()

        pyxel.run(self.update, self.draw)

    # ───────── RESET GAME 1 ─────────
    def reset_game1(self):
        self.player_x = 230
        self.player_y = 125
        self.player_speed = 2
        self.player_w = 12
        self.player_h = 12
        self.player_dir = "right"

        self.bullets = []
        self.enemies = []
        self.particles = []

        self.score = 0
        self.max_hearts = 4
        self.hearts = 4

        self.invincible_timer = 0
        self.shoot_cooldown = 0

        self.wave = 1
        self.wave_banner_timer = 90
        self.wave_cleared_timer = 0
        self.wave_spawned = False

        self.spawn_wave(self.wave)

    # ───────── RESET GAME 2 (PONG) ─────────
    def reset_game2(self):
        self.paddle_y = H // 2 - 20
        self.enemy_y = H // 2 - 20
        self.ball_x = W // 2
        self.ball_y = H // 2
        self.ball_vx = 3
        self.ball_vy = 2
        self.player_score = 0
        self.enemy_score = 0
        self.game2_over = False
        self.game2_winner = ""

    # ───────── INIT / START GAME 3 (RANDOM ACCESS MATCH) ─────────
    def init_game3(self):
        self.g3_speed = 2
        self.g3_card_w = 40
        self.g3_card_h = 40
        self.g3_grid_rows = 4
        self.g3_grid_cols = 4
        self.g3_cards = []
        self.g3_flipped = []
        self.g3_revealed = []
        self.g3_flip_timer = None
        self.g3_congrats_start = None
        self.g3_congrats_flash_count = 0
        self.g3_congrats_show = False

        self.g3_shapes = [
            ("heart", 14),
            ("square", 11),
            ("circle", 12),
            ("rectangle", 9),
            ("diamond", 6),
            ("oval", 15),
            ("trapezoid", 8),
            ("hexagon", 10)
        ]

        self.prepare_game3_cards()

    def start_game3(self):
        self.g3_flipped = []
        self.g3_revealed = []
        self.g3_flip_timer = None
        self.g3_congrats_start = None
        self.g3_congrats_flash_count = 0
        self.g3_congrats_show = False
        self.g3_px = W // 2
        self.g3_py = H // 2

        for card in self.g3_cards:
            card["flipped"] = False

    def prepare_game3_cards(self):
        card_shapes = self.g3_shapes * 2
        random.shuffle(card_shapes)
        self.g3_cards = []

        for i in range(self.g3_grid_rows):
            for j in range(self.g3_grid_cols):
                x = 60 + j * (self.g3_card_w + 5)
                y = 50 + i * (self.g3_card_h + 5)
                shape, col = card_shapes.pop()
                self.g3_cards.append({
                    "x": x,
                    "y": y,
                    "shape": shape,
                    "color": col,
                    "flipped": False
                })

    # ───────── RESET GAME 4 (SPACE INVADERS) ─────────
    def reset_game4(self):
        self.g4_player_x = W // 2 - 8
        self.g4_player_y = H - 20
        self.g4_player_speed = 3

        self.g4_bullets = []
        self.g4_enemy_bullets = []

        self.g4_enemy_rows = 3
        self.g4_enemy_cols = 8
        self.g4_enemies = []
        self.g4_enemy_dir = 1
        self.g4_enemy_speed = 0.6
        self.g4_enemy_drop = 10

        self.g4_score = 0
        self.g4_lives = 3
        self.g4_shoot_cooldown = 0
        self.g4_enemy_shoot_timer = 0

        self.g4_game_over = False
        self.g4_win = False

        start_x = 40
        start_y = 35
        spacing_x = 28
        spacing_y = 20

        for row in range(self.g4_enemy_rows):
            for col in range(self.g4_enemy_cols):
                self.g4_enemies.append({
                    "x": start_x + col * spacing_x,
                    "y": start_y + row * spacing_y,
                    "alive": True
                })

    # ───────── UPDATE ─────────
    def update(self):
        if pyxel.btnp(pyxel.KEY_ESCAPE):
            pyxel.quit()

        if self.state == "menu":
            if pyxel.btnp(pyxel.KEY_DOWN):
                self.selected = (self.selected + 1) % len(self.games)

            if pyxel.btnp(pyxel.KEY_UP):
                self.selected = (self.selected - 1) % len(self.games)

            if pyxel.btnp(pyxel.KEY_RETURN):
                self.state = f"game_{self.selected + 1}"

                if self.state == "game_1":
                    self.reset_game1()
                elif self.state == "game_2":
                    self.reset_game2()
                elif self.state == "game_3":
                    self.prepare_game3_cards()
                    self.start_game3()
                elif self.state == "game_4":
                    self.reset_game4()

        elif self.state == "game_1":
            self.update_game1()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_1_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game1()
                self.state = "game_1"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_1_win":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game1()
                self.state = "game_1"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_2":
            self.update_game2()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_2_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game2()
                self.state = "game_2"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_3":
            self.update_game3()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4":
            self.update_game4()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game4()
                self.state = "game_4"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4_win":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game4()
                self.state = "game_4"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state.startswith("game_"):
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

    # ───────── GAME 1 UPDATE ─────────
    def update_game1(self):
        if self.wave_banner_timer > 0:
            self.wave_banner_timer -= 1

        if self.wave_cleared_timer > 0:
            self.wave_cleared_timer -= 1
            self.update_particles()

            if self.wave_cleared_timer == 0:
                self.wave += 1
                if self.wave > self.max_waves:
                    self.state = "game_1_win"
                    return
                self.spawn_wave(self.wave)
                self.wave_banner_timer = 90
            return

        dx = 0
        dy = 0

        if pyxel.btn(pyxel.KEY_A) or pyxel.btn(pyxel.KEY_LEFT):
            dx = -self.player_speed
            self.player_dir = "left"
        if pyxel.btn(pyxel.KEY_D) or pyxel.btn(pyxel.KEY_RIGHT):
            dx = self.player_speed
            self.player_dir = "right"
        if pyxel.btn(pyxel.KEY_W) or pyxel.btn(pyxel.KEY_UP):
            dy = -self.player_speed
            self.player_dir = "up"
        if pyxel.btn(pyxel.KEY_S) or pyxel.btn(pyxel.KEY_DOWN):
            dy = self.player_speed
            self.player_dir = "down"

        self.player_x += dx
        self.player_y += dy

        self.player_x = max(20, min(self.player_x, W - 32))
        self.player_y = max(28, min(self.player_y, H - 28))

        if self.shoot_cooldown > 0:
            self.shoot_cooldown -= 1

        if pyxel.btn(pyxel.KEY_SPACE) and self.shoot_cooldown == 0:
            self.spawn_bullet()
            self.shoot_cooldown = 10

        if self.invincible_timer > 0:
            self.invincible_timer -= 1

        self.update_bullets()
        self.update_enemies()
        self.update_particles()
        self.check_bullet_enemy_collisions()
        self.check_enemy_player_collisions()
        self.cleanup_enemies()

        if self.hearts <= 0:
            self.state = "game_1_over"
            return

        if len(self.enemies) == 0 and self.wave_cleared_timer == 0:
            self.wave_cleared_timer = 70

    def spawn_wave(self, wave_num):
        self.enemies = []
        enemy_count = 2 + wave_num * 2

        for _ in range(enemy_count):
            ex, ey = self.random_edge_spawn()
            speed = min(0.45 + wave_num * 0.12 + random.uniform(-0.05, 0.08), 1.3)

            enemy_type = "normal"
            if wave_num >= 3 and random.random() < 0.25:
                enemy_type = "fast"
                speed += 0.35

            self.enemies.append({
                "x": ex,
                "y": ey,
                "alive": True,
                "speed": speed,
                "type": enemy_type,
            })

    def random_edge_spawn(self):
        side = random.randint(0, 3)

        if side == 0:
            return random.randint(40, W - 40), 35
        elif side == 1:
            return random.randint(40, W - 40), H - 45
        elif side == 2:
            return 40, random.randint(40, H - 40)
        else:
            return W - 45, random.randint(40, H - 40)

    def spawn_bullet(self):
        bx = self.player_x + 6
        by = self.player_y + 6
        speed = 4.5

        vx, vy = 0, 0
        if self.player_dir == "right":
            vx = speed
            bx += 10
            by += 1
        elif self.player_dir == "left":
            vx = -speed
            bx -= 2
            by += 1
        elif self.player_dir == "up":
            vy = -speed
            bx += 3
            by -= 2
        elif self.player_dir == "down":
            vy = speed
            bx += 3
            by += 10

        self.bullets.append({"x": bx, "y": by, "vx": vx, "vy": vy, "life": 60})

        for _ in range(3):
            self.particles.append({
                "x": bx,
                "y": by,
                "vx": random.uniform(-0.4, 0.4),
                "vy": random.uniform(-0.4, 0.4),
                "life": 8,
                "col": 10
            })

    def update_bullets(self):
        for bullet in self.bullets:
            bullet["x"] += bullet["vx"]
            bullet["y"] += bullet["vy"]
            bullet["life"] -= 1

        self.bullets = [
            b for b in self.bullets
            if 0 <= b["x"] <= W and 0 <= b["y"] <= H and b["life"] > 0
        ]

    def update_enemies(self):
        for enemy in self.enemies:
            if not enemy["alive"]:
                continue

            dx = self.player_x - enemy["x"]
            dy = self.player_y - enemy["y"]
            dist = math.sqrt(dx * dx + dy * dy)

            if dist != 0:
                enemy["x"] += (dx / dist) * enemy["speed"]
                enemy["y"] += (dy / dist) * enemy["speed"]

    def update_particles(self):
        for p in self.particles:
            p["x"] += p["vx"]
            p["y"] += p["vy"]
            p["life"] -= 1

        self.particles = [p for p in self.particles if p["life"] > 0]

    def check_bullet_enemy_collisions(self):
        bullets_to_remove = []

        for bullet in self.bullets:
            for enemy in self.enemies:
                if not enemy["alive"]:
                    continue

                if (
                    bullet["x"] >= enemy["x"]
                    and bullet["x"] <= enemy["x"] + 10
                    and bullet["y"] >= enemy["y"]
                    and bullet["y"] <= enemy["y"] + 12
                ):
                    enemy["alive"] = False
                    bullets_to_remove.append(bullet)
                    self.score += 1

                    for _ in range(8):
                        self.particles.append({
                            "x": enemy["x"] + 5,
                            "y": enemy["y"] + 5,
                            "vx": random.uniform(-1.0, 1.0),
                            "vy": random.uniform(-1.0, 1.0),
                            "life": random.randint(10, 18),
                            "col": 7 if enemy["type"] == "normal" else 10
                        })
                    break

        self.bullets = [b for b in self.bullets if b not in bullets_to_remove]

    def check_enemy_player_collisions(self):
        if self.invincible_timer > 0:
            return

        player_left = self.player_x + 2
        player_right = self.player_x + 10
        player_top = self.player_y
        player_bottom = self.player_y + 12

        for enemy in self.enemies:
            if not enemy["alive"]:
                continue

            enemy_left = enemy["x"] + 1
            enemy_right = enemy["x"] + 9
            enemy_top = enemy["y"]
            enemy_bottom = enemy["y"] + 11

            overlap = (
                player_right >= enemy_left
                and player_left <= enemy_right
                and player_bottom >= enemy_top
                and player_top <= enemy_bottom
            )

            if overlap:
                self.hearts -= 1
                self.invincible_timer = 50

                if self.player_x < enemy["x"]:
                    self.player_x -= 10
                else:
                    self.player_x += 10

                if self.player_y < enemy["y"]:
                    self.player_y -= 10
                else:
                    self.player_y += 10

                self.player_x = max(20, min(self.player_x, W - 32))
                self.player_y = max(28, min(self.player_y, H - 28))

                enemy["alive"] = False

                for _ in range(6):
                    self.particles.append({
                        "x": enemy["x"] + 5,
                        "y": enemy["y"] + 5,
                        "vx": random.uniform(-0.9, 0.9),
                        "vy": random.uniform(-0.9, 0.9),
                        "life": random.randint(8, 14),
                        "col": 8
                    })
                break

    def cleanup_enemies(self):
        self.enemies = [e for e in self.enemies if e["alive"]]

    # ───────── GAME 2 UPDATE (PONG) ─────────
    def update_game2(self):
        if self.game2_over:
            return

        if pyxel.btn(pyxel.KEY_UP):
            self.paddle_y -= 4
        if pyxel.btn(pyxel.KEY_DOWN):
            self.paddle_y += 4

        self.paddle_y = max(0, min(H - 40, self.paddle_y))

        if self.ball_y > self.enemy_y + 20:
            self.enemy_y += 3
        elif self.ball_y < self.enemy_y + 20:
            self.enemy_y -= 3

        self.enemy_y = max(0, min(H - 40, self.enemy_y))

        self.ball_x += self.ball_vx
        self.ball_y += self.ball_vy

        if self.ball_y <= 3 or self.ball_y >= H - 3:
            self.ball_vy *= -1

        if (
            self.ball_x <= 15
            and self.paddle_y <= self.ball_y <= self.paddle_y + 40
            and self.ball_vx < 0
        ):
            self.ball_vx *= -1

        if (
            self.ball_x >= W - 15
            and self.enemy_y <= self.ball_y <= self.enemy_y + 40
            and self.ball_vx > 0
        ):
            self.ball_vx *= -1

        if self.ball_x < 0:
            self.enemy_score += 1
            self.ball_x = W // 2
            self.ball_y = H // 2
            self.ball_vx = 3
            self.ball_vy = random.choice([-2, 2])

        if self.ball_x > W:
            self.player_score += 1
            self.ball_x = W // 2
            self.ball_y = H // 2
            self.ball_vx = -3
            self.ball_vy = random.choice([-2, 2])

        if self.player_score >= 5:
            self.game2_over = True
            self.game2_winner = "YOU WIN!"
            self.state = "game_2_over"
        elif self.enemy_score >= 5:
            self.game2_over = True
            self.game2_winner = "YOU LOSE!"
            self.state = "game_2_over"

    # ───────── GAME 3 UPDATE (RANDOM ACCESS MATCH) ─────────
    def update_game3(self):
        if pyxel.btn(pyxel.KEY_LEFT):
            self.g3_px -= self.g3_speed
        if pyxel.btn(pyxel.KEY_RIGHT):
            self.g3_px += self.g3_speed
        if pyxel.btn(pyxel.KEY_UP):
            self.g3_py -= self.g3_speed
        if pyxel.btn(pyxel.KEY_DOWN):
            self.g3_py += self.g3_speed

        self.g3_px = max(5, min(W - 5, self.g3_px))
        self.g3_py = max(5, min(H - 5, self.g3_py))

        if pyxel.btnp(pyxel.KEY_SPACE):
            for card in self.g3_cards:
                if self.is_on_game3_card(card) and card not in self.g3_flipped + self.g3_revealed:
                    card["flipped"] = True
                    self.g3_flipped.append(card)
                    if len(self.g3_flipped) == 2:
                        self.check_game3_match()
                    break

        if self.g3_flip_timer:
            if time.time() - self.g3_flip_timer > 0.5:
                for card in self.g3_flipped:
                    card["flipped"] = False
                self.g3_flipped = []
                self.g3_flip_timer = None

        if len(self.g3_revealed) == 16 and not self.g3_congrats_start:
            self.g3_congrats_start = time.time()
            self.g3_congrats_flash_count = 0
            self.g3_congrats_show = True

        if self.g3_congrats_start and self.g3_congrats_flash_count < 6:
            if time.time() - self.g3_congrats_start > 0.5:
                self.g3_congrats_show = not self.g3_congrats_show
                self.g3_congrats_start = time.time()
                self.g3_congrats_flash_count += 1
        elif self.g3_congrats_flash_count >= 6:
            self.g3_congrats_show = True

    def is_on_game3_card(self, card):
        return (
            self.g3_px >= card["x"] and self.g3_px <= card["x"] + self.g3_card_w and
            self.g3_py >= card["y"] and self.g3_py <= card["y"] + self.g3_card_h
        )

    def check_game3_match(self):
        a, b = self.g3_flipped
        if a["shape"] == b["shape"]:
            self.g3_revealed += [a, b]
            self.g3_flipped = []
        else:
            self.g3_flip_timer = time.time()

    # ───────── GAME 4 UPDATE (SPACE INVADERS) ─────────
    def update_game4(self):
        if pyxel.btn(pyxel.KEY_LEFT):
            self.g4_player_x -= self.g4_player_speed
        if pyxel.btn(pyxel.KEY_RIGHT):
            self.g4_player_x += self.g4_player_speed

        self.g4_player_x = max(10, min(W - 20, self.g4_player_x))

        if self.g4_shoot_cooldown > 0:
            self.g4_shoot_cooldown -= 1

        if pyxel.btnp(pyxel.KEY_SPACE) and self.g4_shoot_cooldown == 0:
            self.g4_bullets.append({
                "x": self.g4_player_x + 7,
                "y": self.g4_player_y - 4
            })
            self.g4_shoot_cooldown = 10

        for bullet in self.g4_bullets:
            bullet["y"] -= 5
        self.g4_bullets = [b for b in self.g4_bullets if b["y"] > 0]

        move_down = False
        alive_enemies = [e for e in self.g4_enemies if e["alive"]]

        if alive_enemies:
            leftmost = min(e["x"] for e in alive_enemies)
            rightmost = max(e["x"] for e in alive_enemies)

            if rightmost >= W - 20 and self.g4_enemy_dir == 1:
                self.g4_enemy_dir = -1
                move_down = True
            elif leftmost <= 10 and self.g4_enemy_dir == -1:
                self.g4_enemy_dir = 1
                move_down = True

            for enemy in self.g4_enemies:
                if enemy["alive"]:
                    enemy["x"] += self.g4_enemy_dir * self.g4_enemy_speed
                    if move_down:
                        enemy["y"] += self.g4_enemy_drop

        for bullet in self.g4_bullets[:]:
            for enemy in self.g4_enemies:
                if enemy["alive"]:
                    if (
                        bullet["x"] >= enemy["x"]
                        and bullet["x"] <= enemy["x"] + 12
                        and bullet["y"] >= enemy["y"]
                        and bullet["y"] <= enemy["y"] + 8
                    ):
                        enemy["alive"] = False
                        self.g4_score += 10
                        if bullet in self.g4_bullets:
                            self.g4_bullets.remove(bullet)
                        break

        if self.g4_enemy_shoot_timer > 0:
            self.g4_enemy_shoot_timer -= 1
        else:
            shooters = []
            for col in range(self.g4_enemy_cols):
                col_enemies = [
                    e for e in self.g4_enemies
                    if e["alive"] and round((e["x"] - 40) / 28) == col
                ]
                if col_enemies:
                    shooters.append(max(col_enemies, key=lambda e: e["y"]))

            if shooters:
                shooter = random.choice(shooters)
                self.g4_enemy_bullets.append({
                    "x": shooter["x"] + 6,
                    "y": shooter["y"] + 8
                })

            self.g4_enemy_shoot_timer = random.randint(30, 60)

        for bullet in self.g4_enemy_bullets:
            bullet["y"] += 3
        self.g4_enemy_bullets = [b for b in self.g4_enemy_bullets if b["y"] < H]

        player_left = self.g4_player_x
        player_right = self.g4_player_x + 14
        player_top = self.g4_player_y
        player_bottom = self.g4_player_y + 8

        for bullet in self.g4_enemy_bullets[:]:
            if (
                bullet["x"] >= player_left
                and bullet["x"] <= player_right
                and bullet["y"] >= player_top
                and bullet["y"] <= player_bottom
            ):
                self.g4_lives -= 1
                self.g4_enemy_bullets.remove(bullet)
                if self.g4_lives <= 0:
                    self.state = "game_4_over"
                    return

        for enemy in self.g4_enemies:
            if enemy["alive"] and enemy["y"] + 8 >= self.g4_player_y:
                self.state = "game_4_over"
                return

        if all(not e["alive"] for e in self.g4_enemies):
            self.state = "game_4_win"

    # ───────── DRAW ─────────
    def draw(self):
        pyxel.cls(0)

        if self.state == "menu":
            self.draw_menu()
        elif self.state == "game_1":
            self.draw_game1()
        elif self.state == "game_1_over":
            self.draw_game1_over()
        elif self.state == "game_1_win":
            self.draw_game1_win()
        elif self.state == "game_2":
            self.draw_game2()
        elif self.state == "game_2_over":
            self.draw_game2_over()
        elif self.state == "game_3":
            self.draw_game3()
        elif self.state == "game_4":
            self.draw_game4()
        elif self.state == "game_4_over":
            self.draw_game4_over()
        elif self.state == "game_4_win":
            self.draw_game4_win()
        else:
            self.draw_placeholder()

    # ───────── MENU DRAW ─────────
    def draw_menu(self):
        for y in range(H):
            pyxel.line(0, y, W, y, 1 if y < H // 2 else 0)

        title = "PYXEL PORT"
        scale = 4
        start_x = (W - len(title) * (3 * scale + scale)) // 2
        y = 40

        for i, ch in enumerate(title):
            self.draw_block_char(start_x + i * (3 * scale + scale), y, ch, scale, 8)

        if pyxel.frame_count % 40 < 20:
            text = "INSERT COIN"
            pyxel.text((W - len(text) * 4) // 2, 95, text, 10)

        pyxel.rect(80, 102, 160, 110, 0)
        pyxel.rectb(80, 102, 160, 110, 7)

        for i, game in enumerate(self.games):
            yy = 122 + i * 14
            if i == self.selected:
                pyxel.circ(95, yy + 3, 2, 10)
            pyxel.text(110, yy, game, 7)

    # ───────── GAME 1 DRAW ─────────
    def draw_game1(self):
        self.draw_dungeon_room()
        self.draw_ui()

        for enemy in self.enemies:
            self.draw_skeleton(int(enemy["x"]), int(enemy["y"]), enemy["type"])

        for bullet in self.bullets:
            pyxel.circ(int(bullet["x"]), int(bullet["y"]), 1, 10)

        for p in self.particles:
            pyxel.pset(int(p["x"]), int(p["y"]), p["col"])

        if self.invincible_timer == 0 or pyxel.frame_count % 6 < 3:
            self.draw_player(int(self.player_x), int(self.player_y))

        pyxel.text(8, H - 10, "WASD move  SPACE shoot  TAB menu", 7)

        if self.wave_banner_timer > 0:
            banner = f"WAVE {self.wave}"
            pyxel.rect(120, 18, 80, 16, 0)
            pyxel.rectb(120, 18, 80, 16, 7)
            pyxel.text((W - len(banner) * 4) // 2, 24, banner, 10)

        if self.wave_cleared_timer > 0:
            text = "WAVE CLEAR!"
            pyxel.rect(110, 105, 100, 18, 0)
            pyxel.rectb(110, 105, 100, 18, 7)
            pyxel.text((W - len(text) * 4) // 2, 111, text, 11)

