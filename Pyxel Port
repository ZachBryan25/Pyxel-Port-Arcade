        else:
            self.g5_draw_empty_slot(STOCK_X, STOCK_Y)

        if self.g5_waste:
            selected = self.g5_selected_source == ("waste", None)
            self.g5_draw_card(WASTE_X, WASTE_Y, self.g5_waste[-1], selected)
        else:
            self.g5_draw_empty_slot(WASTE_X, WASTE_Y)

        for i in range(4):
            x = FOUNDATION_X_START + i * PILE_SPACING_X
            y = FOUNDATION_Y
            pile = self.g5_foundations[i]
            if pile:
                selected = self.g5_selected_source == ("foundation", i)
                self.g5_draw_card(x, y, pile[-1], selected)
            else:
                self.g5_draw_empty_slot(x, y)

        for col in range(7):
            x = TABLEAU_X_START + col * PILE_SPACING_X
            y = TABLEAU_Y
            pile = self.g5_tableau[col]

            if not pile:
                self.g5_draw_empty_slot(x, y)
                continue

            for i, card in enumerate(pile):
                cy = y + i * TABLEAU_GAP_Y

                selected = False
                if self.g5_selected_source and self.g5_selected_source[0] == "tableau":
                    src_col = self.g5_selected_source[1]
                    src_index = self.g5_selected_source[2]
                    if src_col == col and i >= src_index:
                        selected = True

                self.g5_draw_card(x, cy, card, selected)

        pyxel.text(10, H - 18, "Click cards to select/move  R=restart  TAB=menu", 7)

        if self.g5_message:
            pyxel.text(10, H - 9, self.g5_message, 8)

