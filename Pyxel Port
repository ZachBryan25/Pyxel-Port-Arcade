    def draw_invader(self, x, y):
        pyxel.rect(x + 2, y, 8, 3, 8)
        pyxel.rect(x, y + 3, 12, 3, 8)
        pyxel.rect(x + 2, y + 6, 2, 2, 8)
        pyxel.rect(x + 8, y + 6, 2, 2, 8)
        pyxel.pset(x + 3, y + 1, 0)
        pyxel.pset(x + 8, y + 1, 0)

    def draw_dungeon_room(self):
        pyxel.cls(5)

        pyxel.rect(0, 0, W, 30, 5)
        pyxel.rect(0, H - 30, W, 30, 5)

        for x in range(0, W, 16):
            pyxel.rectb(x, 0, 15, 15, 13)
            pyxel.rectb(x, 15, 15, 15, 1)
            pyxel.rectb(x, H - 30, 15, 15, 13)
            pyxel.rectb(x, H - 15, 15, 15, 1)

        pyxel.rect(0, 30, 32, H - 60, 1)
        pyxel.rect(W - 32, 30, 32, H - 60, 1)

        for y in range(30, H - 30, 16):
            pyxel.rectb(0, y, 16, 15, 13)
            pyxel.rectb(16, y, 16, 15, 13)
            pyxel.rectb(W - 32, y, 16, 15, 13)
            pyxel.rectb(W - 16, y, 16, 15, 13)

        pyxel.rect(32, 30, W - 64, H - 60, 4)

        pyxel.rect(48, 62, 38, 34, 15)
        pyxel.rect(145, 145, 35, 30, 15)

        for (x, y) in [(62, 80), (101, 88), (157, 111), (88, 192), (210, 160), (248, 181)]:
            pyxel.line(x, y, x + 4, y, 1)
            pyxel.line(x + 2, y - 2, x + 2, y + 2, 1)

        self.draw_portal(170, 90)

        pyxel.rect(6, 108, 18, 6, 12)
        pyxel.rect(10, 114, 10, 4, 6)

        pyxel.rect(W - 24, 100, 16, 36, 1)

    def draw_portal(self, x, y):
        pyxel.rect(x - 10, y - 2, 20, 16, 13)
        pyxel.rect(x - 14, y - 6, 28, 10, 13)
        pyxel.circ(x, y + 2, 10, 12)
        pyxel.circ(x, y + 2, 8, 11)
        pyxel.pset(x, y, 7)
        pyxel.circ(x + 12, y + 14, 4, 3)

    def draw_ui(self):
        self.draw_big_digit(self.wave, 6, 58, 9)

        heart_x = 26
        for i in range(self.hearts):
            self.draw_heart(heart_x + i * 30, 10)

        pyxel.text(W - 58, 8, f"SCORE:{self.score}", 7)

    def draw_heart(self, x, y):
        pyxel.circ(x + 4, y + 4, 4, 8)
        pyxel.circ(x + 10, y + 4, 4, 8)
        pyxel.tri(x, y + 7, x + 14, y + 7, x + 7, y + 16, 8)

    def draw_big_digit(self, digit, x, y, col):
        patterns = {
            "1": ["11", "01", "01", "01", "11"],
            "2": ["111", "001", "111", "100", "111"],
            "3": ["111", "001", "111", "001", "111"],
            "4": ["101", "101", "111", "001", "001"],
            "5": ["111", "100", "111", "001", "111"]
        }
        pattern = patterns.get(str(digit), patterns["1"])
        s = 5
        for row, line in enumerate(pattern):
            for col_i, bit in enumerate(line):
                if bit == "1":
                    pyxel.rect(x + col_i * s, y + row * s, s, s, col)

    def draw_player(self, x, y):
        pyxel.ellib(x + 2, y + 10, 10, 3, 1)

        if self.player_dir == "right":
            pyxel.rect(x + 4, y, 3, 4, 15)
            pyxel.rect(x + 3, y + 4, 5, 5, 12)
            pyxel.rect(x + 7, y + 4, 4, 2, 0)
            pyxel.rect(x + 9, y + 3, 3, 1, 12)
            pyxel.rect(x + 10, y + 5, 2, 1, 6)
            pyxel.rect(x + 4, y + 9, 2, 3, 5)
            pyxel.rect(x + 6, y + 9, 2, 3, 5)

        elif self.player_dir == "left":
            pyxel.rect(x + 5, y, 3, 4, 15)
            pyxel.rect(x + 4, y + 4, 5, 5, 12)
            pyxel.rect(x, y + 4, 4, 2, 0)
            pyxel.rect(x, y + 3, 3, 1, 12)
            pyxel.rect(x, y + 5, 2, 1, 6)
            pyxel.rect(x + 4, y + 9, 2, 3, 5)
            pyxel.rect(x + 6, y + 9, 2, 3, 5)

        elif self.player_dir == "up":
            pyxel.rect(x + 4, y + 1, 3, 3, 15)
            pyxel.rect(x + 3, y + 4, 5, 5, 12)
            pyxel.rect(x + 5, y - 1, 2, 4, 0)
            pyxel.rect(x + 4, y - 1, 4, 1, 12)
            pyxel.rect(x + 4, y + 9, 2, 3, 5)
            pyxel.rect(x + 6, y + 9, 2, 3, 5)

        elif self.player_dir == "down":
            pyxel.rect(x + 4, y, 3, 3, 15)
            pyxel.rect(x + 3, y + 3, 5, 5, 12)
            pyxel.rect(x + 5, y + 8, 2, 4, 0)
            pyxel.rect(x + 4, y + 10, 4, 1, 12)
            pyxel.rect(x + 4, y + 9, 2, 3, 5)
            pyxel.rect(x + 6, y + 9, 2, 3, 5)

    def draw_skeleton(self, x, y, enemy_type="normal"):
        pyxel.ellib(x + 1, y + 10, 10, 3, 1)

        skull_col = 7 if enemy_type == "normal" else 10

        pyxel.rect(x + 3, y, 4, 4, skull_col)
        pyxel.pset(x + 4, y + 1, 0)
        pyxel.pset(x + 5, y + 1, 0)

        pyxel.rect(x + 3, y + 4, 4, 4, 7)
        pyxel.rect(x + 1, y + 4, 2, 1, 7)
        pyxel.rect(x + 7, y + 4, 2, 1, 7)
        pyxel.pset(x + 9, y + 4, 8)
        pyxel.rect(x + 3, y + 8, 1, 3, 7)
        pyxel.rect(x + 6, y + 8, 1, 3, 7)

    def draw_block_char(self, x, y, ch, s, col):
        patterns = {
            "P": ["110", "101", "110", "100", "100"],
            "Y": ["101", "101", "010", "010", "010"],
            "X": ["101", "010", "010", "010", "101"],
            "E": ["111", "100", "110", "100", "111"],
            "L": ["100", "100", "100", "100", "111"],
            "O": ["111", "101", "101", "101", "111"],
            "R": ["110", "101", "110", "101", "101"],
            "T": ["111", "010", "010", "010", "010"],
            " ": ["000"]
        }

        pattern = patterns.get(ch, patterns[" "])

        for row, line in enumerate(pattern):
            for col_i, bit in enumerate(line):
                if bit == "1":
                    pyxel.rect(x + col_i * s, y + row * s, s, s, col)

    def draw_placeholder(self):
        pyxel.cls(0)

        game_index = int(self.state.split("_")[1])
        game_name = self.games[game_index - 1]

        msg = f"INSERT {game_name} HERE"
        pyxel.text((W - len(msg) * 4) // 2, H // 2, msg, 7)

        pyxel.text(5, H - 10, "TAB to return", 5)
        esc_text = "ESC to exit"
        pyxel.text(W - len(esc_text) * 4 - 5, H - 10, esc_text, 5)


