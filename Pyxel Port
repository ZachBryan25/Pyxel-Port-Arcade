    def reset_game5(self):
        self.g5_stock = []
        self.g5_waste = []
        self.g5_foundations = [[], [], [], []]
        self.g5_tableau = [[] for _ in range(7)]

        self.g5_selected_cards = None
        self.g5_selected_source = None
        self.g5_message = ""
        self.g5_win = False

        deck = self.g5_create_deck()

        for col in range(7):
            for row in range(col + 1):
                card = deck.pop()
                if row == col:
                    card.face_up = True
                self.g5_tableau[col].append(card)

        self.g5_stock = deck

    def g5_create_deck(self):
        suits = ["H", "D", "C", "S"]
        deck = [Card(suit, rank) for suit in suits for rank in range(1, 14)]
        random.shuffle(deck)
        return deck

    # ───────── UPDATE ─────────
    def update(self):
        if pyxel.btnp(pyxel.KEY_ESCAPE):
            pyxel.quit()

        if self.state == "menu":
            self.start_menu_music()
            self.update_menu()

            if pyxel.btnp(pyxel.KEY_DOWN):
                self.selected = (self.selected + 1) % len(self.games)

            if pyxel.btnp(pyxel.KEY_UP):
                self.selected = (self.selected - 1) % len(self.games)

            if pyxel.btnp(pyxel.KEY_M):
                self.toggle_mute()

            if pyxel.btnp(pyxel.KEY_RETURN):
                self.stop_menu_music()
                self.state = f"game_{self.selected + 1}"

                if self.state == "game_1":
                    self.reset_game1()
                elif self.state == "game_2":
                    self.reset_game2()
                elif self.state == "game_3":
                    self.ram_game.prepare_cards()
                    self.ram_game.start()
                elif self.state == "game_4":
                    self.reset_game4()
                elif self.state == "game_5":
                    self.reset_game5()

        elif self.state == "game_1":
            self.update_game1()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_1_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game1()
                self.state = "game_1"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_1_win":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game1()
                self.state = "game_1"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_2":
            self.update_game2()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_2_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game2()
                self.state = "game_2"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_3":
            self.ram_game.update()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4":
            self.update_game4()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4_over":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game4()
                self.state = "game_4"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_4_win":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game4()
                self.state = "game_4"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_5":
            self.update_game5()
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        elif self.state == "game_5_win":
            if pyxel.btnp(pyxel.KEY_RETURN):
                self.reset_game5()
                self.state = "game_5"
            if pyxel.btnp(pyxel.KEY_TAB):
                self.state = "menu"

        # Resume music when returning to menu from any game
        if self.state == "menu" and not self.music_playing:
            self.start_menu_music()

    # ───────── GAME 1 UPDATE ─────────
    def update_game1(self):
        if self.wave_banner_timer > 0:
            self.wave_banner_timer -= 1

        if self.wave_cleared_timer > 0:
            self.wave_cleared_timer -= 1
            self.update_particles()

            if self.wave_cleared_timer == 0:
                self.wave += 1
                if self.wave > self.max_waves:
                    self.state = "game_1_win"
                    return
                self.spawn_wave(self.wave)
                self.wave_banner_timer = 90
            return

        dx = 0
        dy = 0

        if pyxel.btn(pyxel.KEY_A) or pyxel.btn(pyxel.KEY_LEFT):
            dx = -self.player_speed
            self.player_dir = "left"
        if pyxel.btn(pyxel.KEY_D) or pyxel.btn(pyxel.KEY_RIGHT):
            dx = self.player_speed
            self.player_dir = "right"
        if pyxel.btn(pyxel.KEY_W) or pyxel.btn(pyxel.KEY_UP):
            dy = -self.player_speed
            self.player_dir = "up"
        if pyxel.btn(pyxel.KEY_S) or pyxel.btn(pyxel.KEY_DOWN):
            dy = self.player_speed
            self.player_dir = "down"

        self.player_x += dx
        self.player_y += dy

        self.player_x = max(20, min(self.player_x, W - 32))
        self.player_y = max(28, min(self.player_y, H - 28))

        if self.shoot_cooldown > 0:
            self.shoot_cooldown -= 1

        if pyxel.btn(pyxel.KEY_SPACE) and self.shoot_cooldown == 0:
            self.spawn_bullet()
            self.shoot_cooldown = 10

        if self.invincible_timer > 0:
            self.invincible_timer -= 1

        self.update_bullets()
        self.update_enemies()
        self.update_particles()
        self.check_bullet_enemy_collisions()
        self.check_enemy_player_collisions()
        self.cleanup_enemies()

        if self.hearts <= 0:
            self.state = "game_1_over"
            return

        if len(self.enemies) == 0 and self.wave_cleared_timer == 0:
            self.wave_cleared_timer = 70

    def spawn_wave(self, wave_num):
        self.enemies = []
        enemy_count = 2 + wave_num * 2

        for _ in range(enemy_count):
            ex, ey = self.random_edge_spawn()
            speed = min(0.45 + wave_num * 0.12 + random.uniform(-0.05, 0.08), 1.3)

            enemy_type = "normal"
            if wave_num >= 3 and random.random() < 0.25:
                enemy_type = "fast"
                speed += 0.35

            self.enemies.append({
                "x": ex,
                "y": ey,
                "alive": True,
                "speed": speed,
                "type": enemy_type,
            })

    def random_edge_spawn(self):
        side = random.randint(0, 3)

        if side == 0:
            return random.randint(40, W - 40), 35
        elif side == 1:
            return random.randint(40, W - 40), H - 45
        elif side == 2:
            return 40, random.randint(40, H - 40)
        else:
            return W - 45, random.randint(40, H - 40)

    def spawn_bullet(self):
        bx = self.player_x + 6
        by = self.player_y + 6
        speed = 4.5

        vx, vy = 0, 0
        if self.player_dir == "right":
            vx = speed
            bx += 10
            by += 1
        elif self.player_dir == "left":
            vx = -speed
            bx -= 2
            by += 1
        elif self.player_dir == "up":
            vy = -speed
            bx += 3
            by -= 2
        elif self.player_dir == "down":
            vy = speed
            bx += 3
            by += 10

        self.bullets.append({"x": bx, "y": by, "vx": vx, "vy": vy, "life": 60})

        for _ in range(3):
            self.particles.append({
                "x": bx,
                "y": by,
                "vx": random.uniform(-0.4, 0.4),
                "vy": random.uniform(-0.4, 0.4),
                "life": 8,
                "col": 10
            })

    def update_bullets(self):
        for bullet in self.bullets:
            bullet["x"] += bullet["vx"]
            bullet["y"] += bullet["vy"]
            bullet["life"] -= 1

        self.bullets = [
            b for b in self.bullets
            if 0 <= b["x"] <= W and 0 <= b["y"] <= H and b["life"] > 0
        ]

    def update_enemies(self):
        for enemy in self.enemies:
            if not enemy["alive"]:
                continue

            dx = self.player_x - enemy["x"]
            dy = self.player_y - enemy["y"]
            dist = math.sqrt(dx * dx + dy * dy)

            if dist != 0:
                enemy["x"] += (dx / dist) * enemy["speed"]
                enemy["y"] += (dy / dist) * enemy["speed"]

    def update_particles(self):
        for p in self.particles:
            p["x"] += p["vx"]
            p["y"] += p["vy"]
            p["life"] -= 1

        self.particles = [p for p in self.particles if p["life"] > 0]

    def check_bullet_enemy_collisions(self):
        bullets_to_remove = []

        for bullet in self.bullets:
            for enemy in self.enemies:
                if not enemy["alive"]:
                    continue

                if (
                    bullet["x"] >= enemy["x"]
                    and bullet["x"] <= enemy["x"] + 10
                    and bullet["y"] >= enemy["y"]
                    and bullet["y"] <= enemy["y"] + 12
                ):
                    enemy["alive"] = False
                    bullets_to_remove.append(bullet)
                    self.score += 1

                    for _ in range(8):
                        self.particles.append({
                            "x": enemy["x"] + 5,
                            "y": enemy["y"] + 5,
                            "vx": random.uniform(-1.0, 1.0),
                            "vy": random.uniform(-1.0, 1.0),
                            "life": random.randint(10, 18),
                            "col": 7 if enemy["type"] == "normal" else 10
                        })
                    break

        self.bullets = [b for b in self.bullets if b not in bullets_to_remove]

    def check_enemy_player_collisions(self):
        if self.invincible_timer > 0:
            return

        player_left = self.player_x + 2
        player_right = self.player_x + 10
        player_top = self.player_y
        player_bottom = self.player_y + 12

        for enemy in self.enemies:
            if not enemy["alive"]:
                continue

            enemy_left = enemy["x"] + 1
            enemy_right = enemy["x"] + 9
            enemy_top = enemy["y"]
            enemy_bottom = enemy["y"] + 11

            overlap = (
                player_right >= enemy_left
                and player_left <= enemy_right
                and player_bottom >= enemy_top
                and player_top <= enemy_bottom
            )

            if overlap:
                self.hearts -= 1
                self.invincible_timer = 50

                if self.player_x < enemy["x"]:
                    self.player_x -= 10
                else:
                    self.player_x += 10

                if self.player_y < enemy["y"]:
                    self.player_y -= 10
                else:
                    self.player_y += 10

                self.player_x = max(20, min(self.player_x, W - 32))
                self.player_y = max(28, min(self.player_y, H - 28))

                enemy["alive"] = False

                for _ in range(6):
                    self.particles.append({
                        "x": enemy["x"] + 5,
                        "y": enemy["y"] + 5,
                        "vx": random.uniform(-0.9, 0.9),
                        "vy": random.uniform(-0.9, 0.9),
                        "life": random.randint(8, 14),
                        "col": 8
                    })
                break

    def cleanup_enemies(self):
        self.enemies = [e for e in self.enemies if e["alive"]]

    # ───────── GAME 2 UPDATE (PONG) ─────────
    def update_game2(self):
        if self.game2_over:
            return

        if pyxel.btn(pyxel.KEY_UP):
            self.paddle_y -= 4
        if pyxel.btn(pyxel.KEY_DOWN):
            self.paddle_y += 4

        self.paddle_y = max(0, min(H - 40, self.paddle_y))

        if self.ball_y > self.enemy_y + 20:
            self.enemy_y += 3
        elif self.ball_y < self.enemy_y + 20:
            self.enemy_y -= 3

        self.enemy_y = max(0, min(H - 40, self.enemy_y))

        self.ball_x += self.ball_vx
        self.ball_y += self.ball_vy

        if self.ball_y <= 3 or self.ball_y >= H - 3:
            self.ball_vy *= -1

        if (
            self.ball_x <= 15
            and self.paddle_y <= self.ball_y <= self.paddle_y + 40
            and self.ball_vx < 0
        ):
            self.ball_vx *= -1

        if (
            self.ball_x >= W - 15
            and self.enemy_y <= self.ball_y <= self.enemy_y + 40
            and self.ball_vx > 0
        ):
            self.ball_vx *= -1

        if self.ball_x < 0:
            self.enemy_score += 1
            self.ball_x = W // 2
            self.ball_y = H // 2
            self.ball_vx = 3
            self.ball_vy = random.choice([-2, 2])

        if self.ball_x > W:
            self.player_score += 1
            self.ball_x = W // 2
            self.ball_y = H // 2
            self.ball_vx = -3
            self.ball_vy = random.choice([-2, 2])

        if self.player_score >= 5:
            self.game2_over = True
            self.game2_winner = "YOU WIN!"
            self.state = "game_2_over"
        elif self.enemy_score >= 5:
            self.game2_over = True
            self.game2_winner = "YOU LOSE!"
            self.state = "game_2_over"

    # ───────── GAME 4 UPDATE (SPACE INVADERS) ─────────
    def update_game4(self):
        if pyxel.btn(pyxel.KEY_LEFT):
            self.g4_player_x -= self.g4_player_speed
        if pyxel.btn(pyxel.KEY_RIGHT):
            self.g4_player_x += self.g4_player_speed

        self.g4_player_x = max(10, min(W - 20, self.g4_player_x))

        if self.g4_shoot_cooldown > 0:
            self.g4_shoot_cooldown -= 1

        if pyxel.btnp(pyxel.KEY_SPACE) and self.g4_shoot_cooldown == 0:
            self.g4_bullets.append({
                "x": self.g4_player_x + 7,
                "y": self.g4_player_y - 4
            })
            self.g4_shoot_cooldown = 10

        for bullet in self.g4_bullets:
            bullet["y"] -= 5
        self.g4_bullets = [b for b in self.g4_bullets if b["y"] > 0]

        move_down = False
        alive_enemies = [e for e in self.g4_enemies if e["alive"]]

        if alive_enemies:
            leftmost = min(e["x"] for e in alive_enemies)
            rightmost = max(e["x"] for e in alive_enemies)

            if rightmost >= W - 20 and self.g4_enemy_dir == 1:
                self.g4_enemy_dir = -1
                move_down = True
            elif leftmost <= 10 and self.g4_enemy_dir == -1:
                self.g4_enemy_dir = 1
                move_down = True

            for enemy in self.g4_enemies:
                if enemy["alive"]:
                    enemy["x"] += self.g4_enemy_dir * self.g4_enemy_speed
                    if move_down:
                        enemy["y"] += self.g4_enemy_drop

        for bullet in self.g4_bullets[:]:
            for enemy in self.g4_enemies:
                if enemy["alive"]:
                    if (
                        bullet["x"] >= enemy["x"]
                        and bullet["x"] <= enemy["x"] + 12
                        and bullet["y"] >= enemy["y"]
                        and bullet["y"] <= enemy["y"] + 8
                    ):
                        enemy["alive"] = False
                        self.g4_score += 10
                        if bullet in self.g4_bullets:
                            self.g4_bullets.remove(bullet)
                        break

        if self.g4_enemy_shoot_timer > 0:
            self.g4_enemy_shoot_timer -= 1
        else:
            shooters = []
            for col in range(self.g4_enemy_cols):
                col_enemies = [
                    e for e in self.g4_enemies
                    if e["alive"] and round((e["x"] - 40) / 28) == col
                ]
                if col_enemies:
                    shooters.append(max(col_enemies, key=lambda e: e["y"]))

            if shooters:
                shooter = random.choice(shooters)
                self.g4_enemy_bullets.append({
                    "x": shooter["x"] + 6,
                    "y": shooter["y"] + 8
                })

            self.g4_enemy_shoot_timer = random.randint(30, 60)

        for bullet in self.g4_enemy_bullets:
            bullet["y"] += 3
        self.g4_enemy_bullets = [b for b in self.g4_enemy_bullets if b["y"] < H]

        player_left = self.g4_player_x
        player_right = self.g4_player_x + 14
        player_top = self.g4_player_y
        player_bottom = self.g4_player_y + 8

        for bullet in self.g4_enemy_bullets[:]:
            if (
                bullet["x"] >= player_left
                and bullet["x"] <= player_right
                and bullet["y"] >= player_top
                and bullet["y"] <= player_bottom
            ):
                self.g4_lives -= 1
                self.g4_enemy_bullets.remove(bullet)
                if self.g4_lives <= 0:
                    self.state = "game_4_over"
                    return

        for enemy in self.g4_enemies:
            if enemy["alive"] and enemy["y"] + 8 >= self.g4_player_y:
                self.state = "game_4_over"
                return

        if all(not e["alive"] for e in self.g4_enemies):
            self.state = "game_4_win"

    # ───────── GAME 5 UPDATE (SOLITAIRE) ─────────
    def update_game5(self):
        if self.g5_win:
            return

        if pyxel.btnp(pyxel.KEY_R):
            self.reset_game5()
            return

        if self.g5_check_win():
            self.g5_win = True
            self.state = "game_5_win"
            return

        if pyxel.btnp(pyxel.MOUSE_BUTTON_LEFT):
            mx = pyxel.mouse_x
            my = pyxel.mouse_y
            self.g5_handle_click(mx, my)

    def g5_handle_click(self, mx, my):
        self.g5_message = ""

        if self.g5_point_in_rect(mx, my, STOCK_X, STOCK_Y, CARD_W, CARD_H):
            if self.g5_selected_cards is None:
                self.g5_draw_from_stock()
            else:
                self.g5_clear_selection()
            return

        if self.g5_point_in_rect(mx, my, WASTE_X, WASTE_Y, CARD_W, CARD_H):
            if self.g5_waste:
                if self.g5_selected_cards is None:
                    self.g5_select_waste()
                else:
                    self.g5_try_move_to_waste()
            return

        for i in range(4):
            fx = FOUNDATION_X_START + i * PILE_SPACING_X
            fy = FOUNDATION_Y
            if self.g5_point_in_rect(mx, my, fx, fy, CARD_W, CARD_H):
                if self.g5_selected_cards is None:
                    self.g5_select_foundation(i)
                else:
                    self.g5_try_move_to_foundation(i)
                return

        for col in range(7):
            result = self.g5_get_tableau_clicked(col, mx, my)
            if result is not None:
                clicked_index = result
                if self.g5_selected_cards is None:
                    self.g5_select_tableau(col, clicked_index)
                else:
                    self.g5_try_move_to_tableau(col)
                return

        for col in range(7):
            tx = TABLEAU_X_START + col * PILE_SPACING_X
            ty = TABLEAU_Y
            empty_h = CARD_H if not self.g5_tableau[col] else CARD_H + (len(self.g5_tableau[col]) - 1) * TABLEAU_GAP_Y
            if self.g5_point_in_rect(mx, my, tx, ty, CARD_W, empty_h):
                if self.g5_selected_cards is not None:
                    self.g5_try_move_to_tableau(col)
                    return

        self.g5_clear_selection()

    def g5_draw_from_stock(self):
        if self.g5_stock:
            card = self.g5_stock.pop()
            card.face_up = True
            self.g5_waste.append(card)
        else:
            while self.g5_waste:
                card = self.g5_waste.pop()
                card.face_up = False
                self.g5_stock.append(card)

    def g5_select_waste(self):
        if self.g5_waste:
            self.g5_selected_cards = [self.g5_waste[-1]]
            self.g5_selected_source = ("waste", None)

    def g5_select_foundation(self, foundation_index):
        pile = self.g5_foundations[foundation_index]
        if pile:
            self.g5_selected_cards = [pile[-1]]
            self.g5_selected_source = ("foundation", foundation_index)

    def g5_select_tableau(self, col, index):
        pile = self.g5_tableau[col]
        if index < 0 or index >= len(pile):
            return
        if not pile[index].face_up:
            return
        self.g5_selected_cards = pile[index:]
        self.g5_selected_source = ("tableau", col, index)

    def g5_try_move_to_foundation(self, foundation_index):
        if self.g5_selected_cards is None:
            return
        if len(self.g5_selected_cards) != 1:
            self.g5_message = "Only one card to foundation"
            return
        card = self.g5_selected_cards[0]
        foundation = self.g5_foundations[foundation_index]
        if self.g5_valid_foundation_move(card, foundation):
            self.g5_remove_selected_from_source()
            self.g5_foundations[foundation_index].append(card)
            self.g5_after_tableau_move_cleanup()
            self.g5_clear_selection()
        else:
            self.g5_message = "Invalid foundation move"

    def g5_try_move_to_tableau(self, col):
        if self.g5_selected_cards is None:
            return
        dest_pile = self.g5_tableau[col]
        first_card = self.g5_selected_cards[0]
        if self.g5_selected_source and self.g5_selected_source[0] == "tableau":
            src_col = self.g5_selected_source[1]
            if src_col == col:
                self.g5_clear_selection()
                return
        if self.g5_valid_tableau_move(first_card, dest_pile):
            moved_cards = self.g5_selected_cards[:]
            self.g5_remove_selected_from_source()
            self.g5_tableau[col].extend(moved_cards)
            self.g5_after_tableau_move_cleanup()
            self.g5_clear_selection()
        else:
            self.g5_message = "Invalid tableau move"

    def g5_try_move_to_waste(self):
        self.g5_message = "Cannot move onto waste"

    def g5_remove_selected_from_source(self):
        if self.g5_selected_source is None or self.g5_selected_cards is None:
            return
        source_type = self.g5_selected_source[0]
        if source_type == "waste":
            self.g5_waste.pop()
        elif source_type == "foundation":
            foundation_index = self.g5_selected_source[1]
            self.g5_foundations[foundation_index].pop()
        elif source_type == "tableau":
            col = self.g5_selected_source[1]
            index = self.g5_selected_source[2]
            self.g5_tableau[col] = self.g5_tableau[col][:index]

    def g5_after_tableau_move_cleanup(self):
        if self.g5_selected_source and self.g5_selected_source[0] == "tableau":
            src_col = self.g5_selected_source[1]
            if self.g5_tableau[src_col]:
                if not self.g5_tableau[src_col][-1].face_up:
                    self.g5_tableau[src_col][-1].face_up = True

    def g5_clear_selection(self):
        self.g5_selected_cards = None
        self.g5_selected_source = None

    def g5_valid_foundation_move(self, card, foundation):
        if not foundation:
            return card.rank == 1
        top = foundation[-1]
        return card.suit == top.suit and card.rank == top.rank + 1

    def g5_valid_tableau_move(self, card, dest_pile):
        if not dest_pile:
            return card.rank == 13
        top = dest_pile[-1]
        if not top.face_up:
            return False
        return (card.is_red() != top.is_red()) and (card.rank == top.rank - 1)

    def g5_check_win(self):
        return all(len(f) == 13 for f in self.g5_foundations)

    def g5_get_tableau_clicked(self, col, mx, my):
        pile = self.g5_tableau[col]
        x = TABLEAU_X_START + col * PILE_SPACING_X
        y = TABLEAU_Y
        if not pile:
            return None
        for i in range(len(pile) - 1, -1, -1):
            cy = y + i * TABLEAU_GAP_Y
            h = CARD_H if i == len(pile) - 1 else TABLEAU_GAP_Y + 2
            if self.g5_point_in_rect(mx, my, x, cy, CARD_W, h):
                return i
        return None

    def g5_point_in_rect(self, px, py, x, y, w, h):
        return x <= px < x + w and y <= py < y + h

    # ───────── DRAW ─────────
    def draw(self):
        pyxel.cls(0)

        if self.state == "menu":
            self.draw_menu()
        elif self.state == "game_1":
            self.draw_game1()
        elif self.state == "game_1_over":
            self.draw_game1_over()
        elif self.state == "game_1_win":
            self.draw_game1_win()
        elif self.state == "game_2":
            self.draw_game2()
        elif self.state == "game_2_over":
            self.draw_game2_over()
        elif self.state == "game_3":
            self.ram_game.draw()
        elif self.state == "game_4":
            self.draw_game4()
        elif self.state == "game_4_over":
            self.draw_game4_over()
        elif self.state == "game_4_win":
            self.draw_game4_win()
        elif self.state == "game_5":
            self.draw_game5()
        elif self.state == "game_5_win":
            self.draw_game5_win()

    # ───────── MENU LAYOUT (single source of truth) ─────────
    def _menu_layout(self):
        SCALE         = 4
        CHAR_W        = 3 * SCALE + SCALE
        TITLE         = "PYXEL PORT"
        TITLE_W       = len(TITLE) * CHAR_W
        TITLE_X       = (W - TITLE_W) // 2
        TITLE_Y       = 8
        TITLE_H       = 5 * SCALE
        COIN_Y        = TITLE_Y + TITLE_H + 6

        ROW_H         = 14
        N_GAMES       = len(self.games)
        BOX_PAD_Y     = 8
        BOX_W         = 180
        BOX_H         = BOX_PAD_Y * 2 + N_GAMES * ROW_H
        BOX_X         = (W - BOX_W) // 2

        HINT_Y        = H - 10
        BOX_Y         = HINT_Y - 32 - BOX_H

        FIRST_ENTRY_Y = BOX_Y + BOX_PAD_Y + 2

        return dict(
            SCALE=SCALE, CHAR_W=CHAR_W, TITLE=TITLE,
            TITLE_X=TITLE_X, TITLE_Y=TITLE_Y,
            COIN_Y=COIN_Y,
            ROW_H=ROW_H, N_GAMES=N_GAMES,
            BOX_X=BOX_X, BOX_Y=BOX_Y, BOX_W=BOX_W, BOX_H=BOX_H,
            FIRST_ENTRY_Y=FIRST_ENTRY_Y,
        )

    # ───────── MENU UPDATE ─────────
    def update_menu(self):
        for star in self.stars:
            star["y"] += star["speed"]
            if star["y"] >= H:
                star["y"] = 0
                star["x"] = random.randint(0, W - 1)

        L = self._menu_layout()
        target_y = float(L["FIRST_ENTRY_Y"] + self.selected * L["ROW_H"])
        self.menu_highlight_y += (target_y - self.menu_highlight_y) * 0.18

    # ───────── MENU DRAW ─────────
    def draw_menu(self):
        L = self._menu_layout()
        SCALE         = L["SCALE"]
        CHAR_W        = L["CHAR_W"]
        TITLE         = L["TITLE"]
        TITLE_X       = L["TITLE_X"]
        TITLE_Y       = L["TITLE_Y"]
        COIN_Y        = L["COIN_Y"]
        ROW_H         = L["ROW_H"]
        BOX_X         = L["BOX_X"]
        BOX_Y         = L["BOX_Y"]
        BOX_W         = L["BOX_W"]
        BOX_H         = L["BOX_H"]
        FIRST_ENTRY_Y = L["FIRST_ENTRY_Y"]

        preview = self.menu_preview_rects[self.selected]
        for rx, ry, rw, rh, rc in preview:
            pyxel.rect(rx, ry, rw, rh, rc)

        if self.selected == 0:
            for (x, y) in [(62,80),(101,88),(157,111),(88,152),(210,140)]:
                pyxel.line(x, y, x+4, y, 1)
                pyxel.line(x+2, y-2, x+2, y+2, 1)
        elif self.selected == 1:
            for dash_y in range(0, H, 10):
                pyxel.line(W//2, dash_y, W//2, dash_y+5, 5)
            pyxel.rect(10, H//2-20, 5, 40, 7)
            pyxel.rect(W-15, H//2-20, 5, 40, 7)
        elif self.selected == 2:
            for ci in range(4):
                for cj in range(4):
                    cx = 60 + cj * 45
                    cy = 50 + ci * 35
